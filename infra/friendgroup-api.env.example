NODE_ENV=production
PORT=4000
API_HOST=127.0.0.1
API_BASE_URL=https://api-gem.aidanlenahan.com
WEB_BASE_URL=https://gem.aidanlenahan.com
WEB_ALLOWED_ORIGINS=https://gem.aidanlenahan.com

DATABASE_URL=postgresql://gem:<replace-password>@127.0.0.1:5432/gem_prod
REDIS_URL=redis://127.0.0.1:6379

AUTH_SECRET=<strong-random-secret>
JWT_EXPIRES_IN=7d
CALENDAR_WEBHOOK_SECRET=<calendar-webhook-secret>

VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_SUBJECT=mailto:ops@aidanlenahan.com

S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_BASE_URL=https://api-gem.aidanlenahan.com/media/proxy
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=<minio-access-key>
S3_SECRET_ACCESS_KEY=<minio-secret-key>
S3_BUCKET=gem-media
S3_FORCE_PATH_STYLE=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-password>
EMAIL_FROM=Friendgroup <noreply@gem.aidanlenahan.com>
