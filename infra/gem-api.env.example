NODE_ENV=production
PORT=4000
API_HOST=127.0.0.1
API_BASE_URL=https://api-gem.aidanlenahan.com
WEB_BASE_URL=https://gem.aidanlenahan.com

# Keep existing data identifiers in Phase A (non-destructive)
DATABASE_URL=postgresql://friendgroup:<replace-password>@127.0.0.1:5432/friendgroup_prod
REDIS_URL=redis://127.0.0.1:6379

AUTH_SECRET=<strong-random-secret>

VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_SUBJECT=mailto:ops@aidanlenahan.com

S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_BASE_URL=https://api-gem.aidanlenahan.com/media/proxy
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=<minio-access-key>
S3_SECRET_ACCESS_KEY=<minio-secret-key>
# Keep existing bucket name in Phase A (non-destructive)
S3_BUCKET=friendgroup-media
S3_FORCE_PATH_STYLE=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<smtp-user>
SMTP_PASS=<smtp-password>
EMAIL_FROM=Gem <noreply@gem.aidanlenahan.com>
