{
  "name": "gem",
  "version": "1.0.0",
  "private": true,
  "description": "Gem monorepo",
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:3000": "npm-run-all -p dev:api dev:web:3000",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:web:3000": "npm --workspace apps/web run dev:3000",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace apps/web run build",
    "lint": "npm run -ws --if-present lint",
    "typecheck": "npm run -ws --if-present typecheck",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run prisma migrate dev --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:studio": "npm run prisma studio --workspace=apps/api"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aidanlenahan/gem.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/aidanlenahan/gem/issues"
  },
  "homepage": "https://github.com/aidanlenahan/gem#readme",
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
