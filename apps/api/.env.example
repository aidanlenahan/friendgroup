API_HOST=0.0.0.0
DATABASE_URL=postgresql://friendgroup:friendgroup@localhost:5432/friendgroup_dev
REDIS_URL=redis://localhost:6379
AUTH_SECRET=replace-with-at-least-32-characters-secret
JWT_EXPIRES_IN=7d
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@friendgroup.local
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:4000/media/proxy
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-minio-access-key
S3_SECRET_ACCESS_KEY=replace-with-minio-secret-key
S3_BUCKET=friendgroup-media
S3_FORCE_PATH_STYLE=true
CALENDAR_WEBHOOK_SECRET=replace-with-long-random-secret
# SMTP — Gmail App Password (or any SMTP server)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Friendgroup <noreply@example.com>
WEB_BASE_URL=http://localhost:5173
WEB_ALLOWED_ORIGINS=http://localhost:5173
MEDIA_MAX_FILE_BYTES=10485760
MEDIA_MAX_EVENT_BYTES=209715200
MEDIA_UPLOAD_URL_TTL_SECONDS=900
